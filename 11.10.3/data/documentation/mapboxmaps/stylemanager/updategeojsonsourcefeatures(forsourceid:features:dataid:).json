{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Update existing features in a GeoJSON style source."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":" "},{"kind":"internalParam","text":"sourceId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","text":"Feature","preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"? = nil)"}],"platforms":["iOS"]}]},{"parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}],"name":"features"},{"name":"dataId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The update operation will be scheduled and applied on a GeoJSON serialization queue."}]},{"inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"code":"type = metadata","type":"codeVoice"},{"type":"text","text":" if data parsing error has occurred."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"text":"in a ","type":"text"},{"code":"map-loading-error","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}],"type":"paragraph"}]},{"type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","isActive":true,"type":"reference"},{"type":"text","text":" if there is a problem updating features in the source."}],"type":"paragraph"}],"name":"Throws","style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid:features:dataid:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"updateGeoJSONSourceFeatures"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"text":"Feature","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"?)"}],"modules":[{"name":"MapboxMaps"}],"symbolKind":"method","role":"symbol","title":"updateGeoJSONSourceFe