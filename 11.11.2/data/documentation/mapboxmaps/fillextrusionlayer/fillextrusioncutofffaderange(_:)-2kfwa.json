"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer","navigatorTitle":[{"kind":"identifier","text":"FillExtrusionLayer"}],"abstract":[{"type":"text","text":"An extruded (3D) polygon."}],"kind":"symbol"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer/fillExtrusionCutoffFadeRange(_:)-2kfwa":{"role":"symbol","title":"fillExtrusionCutoffFadeRange(_:)","kind":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/fillextrusionlayer\/fillextrusioncutofffaderange(_:)-2kfwa","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer\/fillExtrusionCutoffFadeRange(_:)-2kfwa","abstract":[{"type":"text","text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled."},{"text":" ","type":"text"},{"text":"Default value: 0. Value range: [0, 1]","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fillExtrusionCutoffFadeRange","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps18FillExtrusionLayerV","kind":"typeIdentifier","text":"FillExtrusionLayer"}]}}}