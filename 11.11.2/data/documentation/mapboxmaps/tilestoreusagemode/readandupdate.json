{"metadata":{"modules":[{"name":"MapboxMaps"}],"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}],"role":"symbol","symbolKind":"case","roleHeading":"Case","externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"title":"TileStoreUsageMode.readAndUpdate"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}],"platforms":["iOS"]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"All tile requests are converted to tile pack requests, i.e.","type":"text"},{"type":"text","text":" "},{"text":"the tile pack that includes the request tile will be loaded, and the tile extracted","type":"text"},{"type":"text","text":" "},{"text":"from it. In this mode, no individual tile requests will be made.","type":"text"}]},{"inlineContent":[{"text":"This mode can be useful if the map trajectory is predefined and the user cannot pan","type":"text"},{"type":"text","text":" "},{"text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded","type":"text"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If users can pan freely, this mode is not recommended. Otherwise, panning"},{"text":" ","type":"text"},{"text":"will download tile packs instead of using individual tiles. Note that this means that we could first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in"},{"type":"text","text":" "},{"type":"text","text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://com.mapbox.MapboxMaps/documentation/Overview":{"type":"topic","kind":"article","title":"MapboxMaps Documentation","abstract":[],"role":"collection","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","url":"\/documentation\/overview"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps":{"title":"MapboxMaps","role":"collection","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","url":"\/documentation\/mapboxmaps","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal."}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode":{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode","url":"\/documentation\/mapboxmaps\/tilestoreusagemode","title":"TileStoreUsageMode","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TileStoreUsageMode","k