ox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewAnnotation","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Use view annotations if you need to display interactive UIView bound to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a geographical coordinate or map feature."}]},{"type":"paragraph","inlineContent":[{"text":"The view annotations are great for displaying unique interactive features. However, they may be suboptimal for large amounts of data and don’t support clustering. For those cases use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true},{"type":"text","text":" or Runtime Styling API, for example, "},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SymbolLayer","isActive":true},{"type":"text","text":" with "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"View Annotations appear above all content of MapView (e.g. layers, annotations, puck). If you need to display annotation between layers or below puck, use ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}]},{"inlineContent":[{"text":"To display a view annotation configure a UIView, create ","type":"text"},{"type":"codeVoice","code":"ViewAnnotation"},{"text":", and add it to the view annotation manager:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The annotation can be displayed on a layer feature referenced by it’s "},{"code":"layerId","type":"codeVoice"},{"type":"text","text":" and "},{"code":"featureId","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["annotation.annotatedFeature = .layerFeature(layerId: \"route-line\", featureId: \"sf-la\")"]},{"inlineContent":[{"text":"The view annotation automatically inserts and removes it’s view into the view hierarchy and updates its ","type":"text"},{"code":"isHidden","type":"codeVoice"},{"text":" property.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"Don’t set "},{"code":"UIView.isHidden","type":"codeVoice"},{"text":" property to hide the annotation. Instead, use ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/visible","type":"reference","isActive":true},{"text":" property.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"inlineContent":[{"text":"When view content or layout is updated, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/setNeedsUpdateSize()"},{"type":"text","text":" to update the the annotation size. It’s safe to use it multiple times, only one update will be performed."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["view.hintText = \"Less Traffic\"","annotation.setNeedsUpdateSize() \/\/ Updates the annotation size."]},{"type":"aside","styl