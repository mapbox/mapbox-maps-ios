{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/fillextrusionlayer\/fillextrusioncutofffaderange"]}],"hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Layers","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fillExtrusionCutoffFadeRange"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps5ValueO","text":"Value","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Value","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":">?"}]}]}],"metadata":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fillExtrusionCutoffFadeRange"},{"kind":"text","text":": "},{"text":"Value","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps5ValueO"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"text":">?","kind":"text"}],"roleHeading":"Instance Property","title":"fillExtrusionCutoffFadeRange","externalID":"s:10MapboxMaps18FillExtrusionLayerV04fillD15CutoffFadeRangeAA5ValueOySdGSgvp","modules":[{"name":"MapboxMaps"}],"role":"symbol","symbolKind":"property"},"kind":"symbol","abstract":[{"text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Default value: 0. Value range: [0, 1]"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer\/fillExtrusionCutoffFadeRange"},"sections":[],"references":{"doc://MapboxMaps/documentation/MapboxMaps/Layers":{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Layers","abstract":[],"url":"\/documentation\/mapboxmaps\/layers","type":"topic","title":"Layers","kind":"article","role":"collectionGroup"},"doc://MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer":{"navigatorTitle":[{"text":"FillExtrusionLayer","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer","url":"\/documentation\/mapboxmaps\/fillextrusionlayer","type":"topic","title":"FillExtrusionLayer","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FillExtrusionLayer"}],"abstract":[{"type":"text","text":"An extruded (3D) polygon."}]},"doc://MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer/fillExtrusionCutoffFadeRange":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fillExtrusionCutoffFadeRange","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Value","preciseIdentifier":"s:10MapboxMaps5ValueO"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":">?","kind":"text"}],"title":"fillExtrusionCutoffFadeRange","type":"topic","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled."},{"text":" ","type":"text"},{"text":"Default value: 0. Value range: [0, 1]","type":"text"}],"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer\/fillExtrusionCutoffFadeRange","url":"\/documentation\/mapboxmaps\/fillextrusionlayer\/fillextrusioncutofffaderange"},"doc://MapboxMaps/documentation/MapboxMaps":{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps","abstract":[{"text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal.","type":"text"}],"url":"\/documentation\/mapboxmaps","type":"topic","title":"MapboxMaps","kind":"symbol","role":"collection"},"doc://MapboxMaps/documentation/MapboxMaps/Value":{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Value","abstract":[],"url":"\/documentation\/mapboxmaps\/value","navigatorTitle":[{"kind":"identifier","text":"Value"}],"type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Value"}],"title":"Value","kind":"symbol","role":"symbol"}}}