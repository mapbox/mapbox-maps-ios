{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"text":" ","kind":"text"},{"text":"sourceId","kind":"internalParam"},{"kind":"text","text":": "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:10MapboxMaps7Featurea","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Feature-swift.typealias","text":"Feature","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"sourceId","content":[{"inlineContent":[{"text":"A style source identifier.","type":"text"}],"type":"paragraph"}]},{"name":"features","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}]},{"content":[{"inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}],"type":"paragraph"}],"name":"dataId"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The update operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"text":"and listen to ","type":"text"},{"type":"codeVoice","code":"onSourceDataLoaded"},{"text":" (optionally pass the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"type":"codeVoice","code":"type = metadata"},{"text":" if data parsing error has occurred.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"text":" ","type":"text"},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"text":" ","type":"text"},{"text":"in a ","type":"text"},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"text":" parameter in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}]}],"style":"note","name":"Note","type":"aside"},{"type":"aside","name":"Throws","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem updating features in the source."}]}]}]}],"metadata":{"modules":[{"name":"MapboxMaps"}],"externalID":"s:10MapboxMaps12StyleManagerC27updateGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier","text":"Feature"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"?)","kind":"text"}],"title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","roleHeading":"Instance Method","role":"symbol"},"identifier":{"url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid: