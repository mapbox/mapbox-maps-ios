dentifier","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"text":"stylePackOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)MBMStylePackLoadOptions","kind":"typeIdentifier","text":"StylePackLoadOptions"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"extraOptions"},{"text":": ","kind":"text"},{"kind":"keyword","text":"Any"},{"text":"?)","kind":"text"}],"roleHeading":"Initializer"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilesetdescriptoroptions\/init(styleuri:zoomrange:pixelratio:tilesets:stylepackoptions:extraoptions:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"convenience","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"text":"styleURI","kind":"externalParam"},{"kind":"text","text":": "},{"text":"StyleURI","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleURI","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps8StyleURIV"},{"text":", ","kind":"text"},{"text":"zoomRange","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ClosedRange","kind":"typeIdentifier","preciseIdentifier":"s:SN"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5UInt8V","text":"UInt8","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"pixelRatio","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Float","kind":"typeIdentifier","preciseIdentifier":"s:Sf"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"tilesets"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"kind":"externalParam","text":"stylePackOptions"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StylePackLoadOptions","text":"StylePackLoadOptions","preciseIdentifier":"c:objc(cs)MBMStylePackLoadOptions"},{"text":"? = nil, ","kind":"text"},{"text":"extraOptions","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Any","kind":"keyword"},{"text":"? = nil)","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The style associated with the tileset descriptor.","type":"text"}],"type":"paragraph"}],"name":"styleURI"},{"name":"zoomRange","content":[{"inlineContent":[{"type":"text","text":"Closed range zoom level for the tile package."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Pixel ratio to be accounted for when downloading raster","type":"text"},{"type":"text","text":" "},{"text":"tiles. Typically this should match the scale used by the ","type":"text"},{"type":"codeVoice","code":"MapView"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"most likely "},{"code":"UIScreen.main.scale","type":"codeVoice"},{"text":", which is the default value.","type":"text"}]}],"name":"pixelRatio"},{"content":[{"inlineContent":[{"type":"text","text":"The tilesets associated with the tileset descriptor. An array, each element of which must be either a URI to a TileJSON resource or a JSON string representing the inline tileset. The provided URIs must have “mapbox:\/\/” scheme, e.g. “mapbox:\/\/mapbox.mapbox-streets-v8”."}],"type":"paragraph"}],"name":"tilesets"},{"name":"stylePackOptions","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Style package load options, associated with the"},{"type":"text","text":" "},{"text":"tileset descriptor.","type":"text"}]}]},{"name":"extraOptions","content":[{"type":"paragraph","inlineContent":[{"text":"Extra tileset descriptor options. Must be a valid JSON object.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The implementation loads and stores the loaded tiles in batches,","type":"text"},{"text":" ","type":"text"},{"text":"each batch has a pre-defined zoom range and it contains all child","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tiles within the range. The zoom leveling scheme for the tile batches"},{"type":"text","text":" "},{"text":"can be defined in Tile JSON, otherwise the default scheme is used:","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Global coverage: 0 - 5"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Regional information: 6 - 10"}]}]},{"content":[{"inlineContent":[{"text":"Local information: 11 - 14","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Streets detail: 15 - 16"}]}]}]},{"inlineContent":[{"type":"text","text":"Internally, the implementation maps the given tile pack zoom range"},{"type":"text","text":" "},{"text":"and geometry to a set of pre-defined batches to load, therefore","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is highly recommended to choose the minZoom and maxZoom values"},{"type":"text","text":" "},{"text":"in accordance with the tile batches zoom ranges (see the list above).","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"If a ","type":"text"},{"type":"codeVoice","code":"stylePackOptions"},{"type":"text","text":" is provided, "},{"code":"OfflineManager","type":"codeVoice"},{"text":" will create a","type":"text"},{"type":"text","text":" "},{"text":"style package while resolving the corresponding tileset descriptor","type":"text"},{"type":"text","text":" "},{"text":"and load all the resources as defined in the provided style package","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"options. i.e. resolving the corresponding tileset descriptor"},{"type":"text","text":" "},{"text":"will be equivalent to calling the ","type":"text"},{"code":"loadStylePack()","type":"codeVoice"},{"type":"text","text":" method of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"OfflineManager"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}],"kind":"content"}],"kind":"symbol","references":{"doc://MapboxMaps/documentation/MapboxMaps/TileStore-APIs":{"title":"TileStore APIs","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","url":"\/documentation\/mapboxmaps\/tilestore-apis","type":"topic","kind":"article","abstract":[],"role":"collectionGroup"},"doc://MapboxMaps/documentation/MapboxMaps":{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps","abstract":[{"text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal.","type":"text"}],"url":"\/documentation\/mapboxmaps","type":"topic","title":"MapboxMaps","kind":"symbol","role":"collection"},"doc://MapboxMaps/documentation/MapboxMaps/StylePackLoadOptions":{"title":"StylePackLoadOptions","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StylePackLoadOptions"}],"abstract":[],"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StylePackLoadOptions","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"StylePackLoadOptions","kind":"identifier"}],"type":"topic","url":"\/documentation\/mapboxmaps\/stylepackloadoptions"},"doc://MapboxMaps/documentation/MapboxMaps/StyleURI":{"kind":"symbol","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleURI","abstract":[{"type":"text","text":"Enum representing the latest version of the Mapbox styles (as of publication). In addition,"},{"type":"text","text":" "},{"text":"you can provide a custom URL or earlier version of a Mapbox style by using ","type":"text"},{"code":"init?(url: URL)","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/