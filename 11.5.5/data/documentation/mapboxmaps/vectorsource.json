 and thus to avoid redundant network requests. Note that tile-network-requests-delay value is superseded with tile-requests-delay property value, if both are provided."},{"text":" ","type":"text"},{"type":"text","text":"Default value: 0."}],"title":"tileNetworkRequestsDelay(_:)","tags":[{"type":"spi","text":"SPI"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/vectorsource\/tilenetworkrequestsdelay(_:)","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/VectorSource\/tileNetworkRequestsDelay(_:)"},"doc://MapboxMaps/documentation/MapboxMaps/GeoJSONSource":{"abstract":[{"type":"text","text":"A GeoJSON data source."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource","type":"topic","title":"GeoJSONSource","url":"\/documentation\/mapboxmaps\/geojsonsource","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"GeoJSONSource"}],"navigatorTitle":[{"kind":"identifier","text":"GeoJSONSource"}]},"doc://MapboxMaps/documentation/MapboxMaps/CustomGeometrySource":{"kind":"symbol","url":"\/documentation\/mapboxmaps\/customgeometrysource","type":"topic","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CustomGeometrySource"}],"title":"CustomGeometrySource","navigatorTitle":[{"text":"CustomGeometrySource","kind":"identifier"}],"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/CustomGeometrySource","abstract":[{"type":"text","text":"Describes a Custom Geometry Source to be used in the style"}]},"doc://MapboxMaps/documentation/MapboxMaps/VectorSource/maxzoom(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"maxzoom"},{"text":"(","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":") -> ","kind":"text"},{"text":"VectorSource","preciseIdentifier":"s:10MapboxMaps12VectorSourceV","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Maximum zoom level for which tiles are available, as in the TileJSON spec. Data from tiles at the maxzoom are used when displaying the map at higher zoom levels."},{"type":"text","text":" "},{"text":"Default value: 22.","type":"text"}],"title":"maxzoom(_:)","tags":[{"text":"SPI","type":"spi"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/vectorsource\/maxzoom(_:)","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/VectorSource\/maxzoom(_:)"},"doc://MapboxMaps/documentation/MapboxMaps/VectorSource/prefetchZoomDelta(_:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"prefetchZoomDelta","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"VectorSource","preciseIdentifier":"s:10MapboxMaps12VectorSourceV","kind":"typeIdentifier"}],"abstract":[{"text":"When loading a map, if PrefetchZoomDelta is set to any number greater than 0, the map will first request a tile at zoom level lower than zoom - delta, but so that the zoom level is multiple of delta, in an attempt to display a full map at lower resolution as quick as possible. It will get clamped at the tile source minimum zoom.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Default value: 4."}],"title":"prefetchZoomDelta(_:)","tags":[{"type":"spi","text":"SPI"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/vectorsource\/prefetchzoomdelta(_:)","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/VectorSource\/prefetchZoomDelta(_:)"},"doc://MapboxMaps/documentation/MapboxMaps/VectorSource/bounds":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"bounds","kind":"identifier"},{"text":": [","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifi