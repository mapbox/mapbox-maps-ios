,{"inlineContent":[{"type":"text","text":"Currently, several types of viewport are supported:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Follow Puck viewport automatically tracks the user’s position on the map.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}]},{"syntax":"swift","type":"codeListing","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"]},{"type":"paragraph","inlineContent":[{"text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:","type":"text"}]},{"syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation","type":"reference","isActive":true},{"type":"text","text":" for more details about viewport animation."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Viewport"},{"text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)"},{"text":" event.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/viewport"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Viewport repres