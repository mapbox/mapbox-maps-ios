t":"(","kind":"text"},{"kind":"externalParam","text":"action"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"preciseIdentifier":"c:objc(cs)MBMCameraChanged","kind":"typeIdentifier","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/CameraChanged","text":"CameraChanged"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"text":"Map","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps3MapV","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"aside","content":[{"inlineContent":[{"text":"This callback is called on every rendering frame. Don’t use it to modify ","type":"text"},{"code":"@State","type":"codeVoice"},{"text":" variables, it will lead to excessive ","type":"text"},{"type":"codeVoice","code":"body"},{"type":"text","text":" execution and higher CPU consumption."}],"type":"paragraph"}],"name":"Important","style":"important"},{"inlineContent":[{"type":"text","text":"For example:"}],"type":"paragraph"},{"type":"codeListing","code":["struct BadExample: View {","    @State var zoom: Double = 0","    var body: some View {","        Map {","            if zoom > 5 {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            \/\/ DON'T DO THIS","            zoom = $0.cameraState.zoom","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Instead update the state only when the actual value is changed:"}],"type":"paragraph"},{"syntax":"swift","code":["struct GoodExample: View {","    private class Model: ObservableObject {","        @Published var showAnnotation = false","        func setZoom(_ zoom: Double) {","            var showAnnotation = zoom < 5","            if showAnnotation != self.showAnnotation {","                \/\/ OK, the showAnnotation updates only when actual value changed.","                \/\/ The `body` will be executed once per update.","                self.showAnnotation = showAnnotation","            }","        }","    }","","    @StateObject var model = Model()","    var body: some View {","        Map {","            if model.showAnnotation {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            model.setZoom($0.cameraState.zoom)","        }","    }","}"],"type":"codeListing"}]}],"abstract":[{"text":"Adds an action to perform when the camera is changed.","type":"text"}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/SwiftUI":{"url":"\/documentation\/mapboxmaps\/swiftui","kind":"article","type":"topic","title":"SwiftUI","role":"collectionGroup","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI","abstract":[]},"doc://com.mapbox.MapboxMaps/documentation/Overview":{"kind":"article","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","title":"MapboxMaps Documentation","abstract":[],"url":"\/documentation\/overview","role":"collection","type":"topic"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/CameraChanged":{"abstract":[{"text":"This event is emitted whenever the visible viewport changes its size","type":"text"},{"type":"text","text":" "},{"text":"due to the invocation of the ","type":"text"},{"type":"codeVoice","code":"setSize"},{"text":" and ","type":"text"},{"code":"setBounds","type":"codeVoice"},{"type":"text","text":" methods or when"},{"text":" ","type":"text"},{"text":"the camera is modified by calling camera methods. The event is emitted","type":"text"},{"type":"text","text":" "},{"text":"synchronously so that an updated camera state can be read immediately.","type":"text"}]