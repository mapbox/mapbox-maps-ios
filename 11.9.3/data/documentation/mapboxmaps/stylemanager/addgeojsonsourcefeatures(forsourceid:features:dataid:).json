rnalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"text":"Feature","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"? = nil)","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The identifier of the style source."}]}]},{"content":[{"inlineContent":[{"text":"An array of GeoJSON features to be added to the source.","type":"text"}],"type":"paragraph"}],"name":"features"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"The add operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"text":" with ","type":"text"},{"code":"type = metadata","type":"codeVoice"},{"text":" if data parsing error has occurred.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"type":"text","text":" "},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"type":"text","text":" "},{"text":"in a ","type":"text"},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}]},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}],"type":"paragraph"}],"type":"aside"},{"type":"aside","name":"Throws","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"}