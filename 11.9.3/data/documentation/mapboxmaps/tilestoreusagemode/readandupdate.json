{"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}],"title":"TileStoreUsageMode.readAndUpdate","modules":[{"name":"MapboxMaps"}],"navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"symbolKind":"case","externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","roleHeading":"Case","role":"symbol"},"kind":"symbol","abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"variants":[{"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"],"traits":[{"interfaceLanguage":"occ"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"All tile requests are converted to tile pack requests, i.e."},{"text":" ","type":"text"},{"type":"text","text":"the tile pack that includes the request tile will be loaded, and the tile extracted"},{"type":"text","text":" "},{"text":"from it. In this mode, no individual tile requests will be made.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This mode can be useful if the map trajectory is predefined and the user cannot pan","type":"text"},{"type":"text","text":" "},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"type":"text","text":" "},{"text":"in the vicinity of the user.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If users can pan freely, this mode is not recommended. Otherwise, panning","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"type":"text","text":" "},{"type":"text","text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in"},{"text":" ","type":"text"},{"text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStore-APIs":{"url":"\/documentation\/mapboxmaps\/tilestore-apis","title":"TileStore APIs","abstract":[],"role":"collectionGroup","kind":"article","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","type":"topic"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode/readAndUpdate":{"title":"TileStoreUsageMode.readAndUpdate","kind":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","url":"\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate","role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"navigatorTitle":[{"kind":"identifier","text":"MBMTileStoreUsageModeReadAndUpdate"}],"type"