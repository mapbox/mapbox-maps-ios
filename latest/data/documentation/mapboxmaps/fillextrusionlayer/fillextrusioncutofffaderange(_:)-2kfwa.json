tation\/MapboxMaps\/FillExtrusionLayer"]]},"abstract":[{"text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Default value: 0. Value range: [0, 1]"}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps":{"url":"\/documentation\/mapboxmaps","kind":"symbol","title":"MapboxMaps","abstract":[{"text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal.","type":"text"}],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","type":"topic","role":"collection"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer/fillExtrusionCutoffFadeRange(_:)-2kfwa":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fillExtrusionCutoffFadeRange","kind":"identifier"},{"kind":"text","text":"("},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:10MapboxMaps18FillExtrusionLayerV","text":"FillExtrusionLayer","kind":"typeIdentifier"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/fillextrusionlayer\/fillextrusioncutofffaderange(_:)-2kfwa","title":"fillExtrusionCutoffFadeRange(_:)","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer\/fillExtrusionCutoffFadeRange(_:)-2kfwa","abstract":[{"type":"text","text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled."},{"type":"text","text":" "},{"text":"Default value: 0. Value range: [0, 1]","type":"text"}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer":{"abstract":[{"type":"text","text":"An extruded (3D) polygon."}],"title":"FillExtrusionLayer","url":"\/documentation\/mapboxmaps\/fillextrusionlayer","role":"symbol","navigatorTitle":[{"text":"FillExtrusionLayer","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FillExtrusionLayer","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Layers":{"url":"\/documentation\/mapboxmaps\/layers","abstract":[],"role":"collectionGroup","kind":"article","type":"topic","title":"Layers","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Layers"},"doc://com.mapbox.MapboxMaps/documentation/Overview":{"role":"collection","url":"\/documentation\/overview","abstract":[],"kind":"article","title":"MapboxMaps Documentation","type":"topic","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview"}}}