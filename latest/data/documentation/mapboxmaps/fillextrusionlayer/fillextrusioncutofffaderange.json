lExtrusionLayer/fillExtrusionCutoffFadeRange":{"title":"fillExtrusionCutoffFadeRange","url":"\/documentation\/mapboxmaps\/fillextrusionlayer\/fillextrusioncutofffaderange","kind":"symbol","type":"topic","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer\/fillExtrusionCutoffFadeRange","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fillExtrusionCutoffFadeRange","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Value","preciseIdentifier":"s:10MapboxMaps5ValueO"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"kind":"text","text":">?"}],"abstract":[{"type":"text","text":"This parameter defines the range for the fade-out effect before an automatic content cutoff on pitched map views. Fade out is implemented by scaling down and removing buildings in the fade range in a staggered fashion. Opacity is not changed. The fade range is expressed in relation to the height of the map view. A value of 1.0 indicates that the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled."},{"type":"text","text":" "},{"type":"text","text":"Default value: 0. Value range: [0, 1]"}],"role":"symbol"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Layers":{"kind":"article","abstract":[],"type":"topic","url":"\/documentation\/mapboxmaps\/layers","role":"collectionGroup","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Layers","title":"Layers"},"doc://com.mapbox.MapboxMaps/documentation/Overview":{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","title":"MapboxMaps Documentation","role":"collection","url":"\/documentation\/overview","kind":"article","abstract":[],"type":"topic"}}}