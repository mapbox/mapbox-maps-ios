hat the content is faded to the same extent as the map’s height in pixels, while a value close to zero represents a sharp cutoff. When the value is set to 0.0, the cutoff is completely disabled. Note: The property has no effect on the map if terrain is enabled.","type":"text"},{"type":"text","text":" "},{"text":"Default value: 0. Value range: [0, 1]","type":"text"}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps":{"role":"collection","title":"MapboxMaps","url":"\/documentation\/mapboxmaps","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","kind":"symbol","abstract":[{"type":"text","text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal."}],"type":"topic"},"doc://com.mapbox.MapboxMaps/documentation/Overview":{"url":"\/documentation\/overview","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","title":"MapboxMaps Documentation","role":"collection","abstract":[],"type":"topic","kind":"article"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/FillExtrusionLayer":{"kind":"symbol","abstract":[{"text":"An extruded (3D) polygon.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FillExtrusionLayer","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"FillExtrusionLayer"}],"title":"FillExtrusionLayer","url":"\/documentation\/mapboxmaps\/fillextrusionlayer","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FillExtrusionLayer"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Value":{"abstract":[],"navigatorTitle":[{"text":"Value","kind":"identifier"}],"title":"Value","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Value","kind":"symbol","type":"topic","url":"\/documentation\/mapboxmaps\/value","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Value"}]}}}