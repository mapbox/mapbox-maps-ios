-> "},{"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Map","text":"Map","preciseIdentifier":"s:10MapboxMaps3MapV","kind":"typeIdentifier"}],"platforms":["iOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"content":[{"inlineContent":[{"text":"This callback is called on every rendering frame. Don’t use it to modify ","type":"text"},{"type":"codeVoice","code":"@State"},{"type":"text","text":" variables, it will lead to excessive "},{"type":"codeVoice","code":"body"},{"type":"text","text":" execution and higher CPU consumption."}],"type":"paragraph"}],"type":"aside","style":"important","name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example:"}]},{"type":"codeListing","syntax":"swift","code":["struct BadExample: View {","    @State var zoom: Double = 0","    var body: some View {","        Map {","            if zoom > 5 {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            \/\/ DON'T DO THIS","            zoom = $0.cameraState.zoom","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Instead update the state only when the actual value is changed:"}]},{"syntax":"swift","code":["struct GoodExample: View {","    private class Model: ObservableObject {","        @Published var showAnnotation = false","        func setZoom(_ zoom: Double) {","            var showAnnotation = zoom < 5","            if showAnnotation != self.showAnnotation {","                \/\/ OK, the showAnnotation updates only when actual value changed.","                \/\/ The `body` will be executed once per update.","                self.showAnnotation = showAnnotation","            }","        }","    }","","    @StateObject var model = Model()","    var body: some View {","        Map {","            if model.showAnnotation {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            model.setZoom($0.cameraState.zoom)","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/mapboxmaps\/map\/oncamerachanged(action:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://MapboxMaps/documentation/MapboxMaps/CameraChanged":{"url":"\/documentation\/mapboxmaps\/camerachanged","kind":"symbol","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/CameraChanged","navigatorTitle":[{"kind":"identifier","text":"CameraChanged"}],"abstract":[],"type":"topic","title":"CameraChanged","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CameraChanged"}]},"doc://MapboxMaps/documentation/MapboxMaps/Map/onCameraChanged(action:)":{"type":"topic","abstract":[{"type":"text","text":"Adds an action to perform when the camera is changed."}],"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","url":"\/documentation\/mapboxmaps\/map\/oncamerachanged(action:)","title":"onCameraChanged(action:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onCameraChanged"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"CameraChanged","preciseIdentifier":"c:objc(cs)MBMCameraChanged","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps3MapV","text":"Map"}],"kind":"symbol"},"doc://MapboxMaps/documentation/MapboxMaps/SwiftUI":{"type":"topic","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/SwiftUI","url":"\/documentation\/mapboxmaps\/swiftui","role":"collectionGroup","title":"SwiftUI","abstract":[