{"abstract":[{"type":"text","text":"Adds an action to perform when the camera is changed."}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onCameraChanged"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"action"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/CameraChanged","preciseIdentifier":"c:objc(cs)MBMCameraChanged","kind":"typeIdentifier","text":"CameraChanged"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps3MapV","kind":"typeIdentifier","text":"Map","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This callback is called on every rendering frame. Don’t use it to modify "},{"code":"@State","type":"codeVoice"},{"type":"text","text":" variables, it will lead to excessive "},{"type":"codeVoice","code":"body"},{"text":" execution and higher CPU consumption.","type":"text"}]}],"style":"important","type":"aside"},{"inlineContent":[{"type":"text","text":"For example:"}],"type":"paragraph"},{"code":["struct BadExample: View {","    @State var zoom: Double = 0","    var body: some View {","        Map {","            if zoom > 5 {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            \/\/ DON'T DO THIS","            zoom = $0.cameraState.zoom","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Instead update the state only when the actual value is changed:"}],"type":"paragraph"},{"syntax":"swift","code":["struct GoodExample: View {","    private class Model: ObservableObject {","        @Published var showAnnotation = false","        func setZoom(_ zoom: Double) {","            var showAnnotation = zoom < 5","            if showAnnotation != self.showAnnotation {","                \/\/ OK, the showAnnotation updates only when actual value changed.","                \/\/ The `body` will be executed once per update.","                self.showAnnotation = showAnnotation","            }","        }","    }","","    @StateObject var model = Model()","    var body: some View {","        Map {","            if model.showAnnotation {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            model.setZoom($0.cameraState.zoom)","        }","    }","}"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map"]]},"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/mapboxmaps\/map\/oncamerachanged(action:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","title":"onCameraChanged(action:)","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onCameraChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": (","kind":"te