O THIS","            zoom = $0.cameraState.zoom","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"Instead update the state only when the actual value is changed:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["struct GoodExample: View {","    private class Model: ObservableObject {","        @Published var showAnnotation = false","        func setZoom(_ zoom: Double) {","            var showAnnotation = zoom < 5","            if showAnnotation != self.showAnnotation {","                \/\/ OK, the showAnnotation updates only when actual value changed.","                \/\/ The `body` will be executed once per update.","                self.showAnnotation = showAnnotation","            }","        }","    }","","    @StateObject var model = Model()","    var body: some View {","        Map {","            if model.showAnnotation {","                CircleAnnotation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            model.setZoom($0.cameraState.zoom)","        }","    }","}"],"syntax":"swift"}],"kind":"content"}],"metadata":{"extendedModule":"MapboxMaps","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onCameraChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"CameraChanged","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)MBMCameraChanged"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps3MapV","text":"Map","kind":"typeIdentifier"}],"symbolKind":"method","modules":[{"name":"MapboxMaps"}],"externalID":"s:10MapboxMaps3MapV15onCameraChanged6actionACySo09MBMCameraF0Cc_tF","role":"symbol","roleHeading":"Instance Method","title":"onCameraChanged(action:)"},"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/o