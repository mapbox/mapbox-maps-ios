tation(centerCoordinate: coordinate)","            }","        }","        .onCameraChanged {","            model.setZoom($0.cameraState.zoom)","        }","    }","}"],"type":"codeListing"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map"]]},"sections":[],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/CameraChanged":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"CameraChanged"}],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"CameraChanged","kind":"identifier"}],"url":"\/documentation\/mapboxmaps\/camerachanged","abstract":[{"type":"text","text":"This event is emitted whenever the visible viewport changes its size"},{"text":" ","type":"text"},{"type":"text","text":"due to the invocation of the "},{"type":"codeVoice","code":"setSize"},{"text":" and ","type":"text"},{"code":"setBounds","type":"codeVoice"},{"text":" methods or when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the camera is modified by calling camera methods. The event is emitted"},{"text":" ","type":"text"},{"text":"synchronously so that an updated camera state can be read immediately.","type":"text"}],"title":"CameraChanged","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/CameraChanged"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Map":{"navigatorTitle":[{"text":"Map","kind":"identifier"}],"url":"\/documentation\/mapboxmaps\/map","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"Map","kind":"identifier"}],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map","kind":"symbol","title":"Map","abstract":[{"type":"text","text":"A SwiftUI view that displays a