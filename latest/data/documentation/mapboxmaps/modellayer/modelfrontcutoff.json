-out effect. A value of 1.0 for final opacity means that the cutoff is completely disabled.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Default value: [0,0,1]. Minimum value: [0,0,0]. Maximum value: [1,1,1]."}],"kind":"symbol","title":"modelFrontCutoff","tags":[{"type":"spi","text":"SPI"}],"role":"symbol","type":"topic"},"doc://MapboxMaps/documentation/MapboxMaps/Layers":{"url":"\/documentation\/mapboxmaps\/layers","type":"topic","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Layers","kind":"article","abstract":[],"role":"collectionGroup","title":"Layers"},"doc://MapboxMaps/documentation/MapboxMaps/ModelLayer":{"abstract":[{"type":"text","text":"A layer to render 3D Models."}],"url":"\/documentation\/mapboxmaps\/modellayer","title":"ModelLayer","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/ModelLayer","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"ModelLayer","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ModelLayer","kind":"identifier"}],"type":"topic","tags":[{"text":"SPI","type":"spi"}]},"doc://MapboxMaps/documentation/MapboxMaps":{"role":"collection","kind":"symbol","abstract":[{"type":"text","text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal."}],"type":"topic","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps","url":"\/documentation\/mapboxmaps","title":"MapboxMaps"}}}