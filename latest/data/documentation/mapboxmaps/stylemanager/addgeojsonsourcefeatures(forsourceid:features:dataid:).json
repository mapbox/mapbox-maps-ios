:" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"type":"text","text":" "},{"text":"call, the data ID in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}]}],"style":"note"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem adding features to the source."}]}],"type":"aside","style":"note","name":"Throws"}]}],"metadata":{"role":"symbol","modules":[{"name":"MapboxMaps"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"Feature","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?)"}],"externalID":"s:10MapboxMaps12StyleManagerC24addGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","symbolKind":"method","roleHeading":"Instance Method","title":"addGeoJSONSourceFeatures(forSourceId:features:dataId:)"},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/Mapbox