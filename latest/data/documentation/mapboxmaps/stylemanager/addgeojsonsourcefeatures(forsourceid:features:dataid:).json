place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"text":"each batch will be included in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}],"type":"paragraph"}],"name":"Note"},{"name":"Throws","type":"aside","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem adding features to the source."}],"type":"paragraph"}]}]}],"abstract":[{"text":"Add additional features to a GeoJSON style source.","type":"text"}],"metadata":{"modules":[{"name":"MapboxMaps"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"features","kind":"externalParam"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps7Featurea","text":"Feature","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"?)","kind":"text"}],"title":"addGeoJSONSourceFeatures(forSourceId:features:dataId:)","roleHeading":"Instance Method","symbolKind":"method","role":"symbol","externalID":"s:10MapboxMaps12StyleManagerC24addGeoJSONSourceFeatures11forSourceId8features04dataK