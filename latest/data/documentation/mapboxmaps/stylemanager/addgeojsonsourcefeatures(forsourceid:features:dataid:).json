xt":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"? = nil)","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The identifier of the style source."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"An array of GeoJSON features to be added to the source."}],"type":"paragraph"}],"name":"features"},{"name":"dataId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The add operation will be scheduled and applied on a GeoJSON serialization queue."}]},{"type":"paragraph","inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"text":" (optionally pass the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter to filter the events)"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"type":"codeVoice","code":"type = metadata"},{"text":" if data parsing error has occurred.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"text":" ","type":"text"},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call, the data ID in the "},{"code":"source-data-loaded","type":"codeVoice"},{"text":"event will be null.","type":"text"}]}],"type":"aside","style":"note","name":"Note"},{"type":"aside","name":"Throws","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem adding features to the source."}],"type":"paragraph"}]}]}],"abstract":[{"type":"text","text":"Add additional features to a GeoJSON style source."}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/addg