{"kind":"symbol","abstract":[{"type":"text","text":"Add additional features to a GeoJSON style source."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addGeoJSONSourceFeatures"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":" "},{"kind":"internalParam","text":"sourceId"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","kind":"typeIdentifier","text":"Feature","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The identifier of the style source.","type":"text"}]}],"name":"sourceId"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An array of GeoJSON features to be added to the source."}]}],"name":"features"},{"name":"dataId","content":[{"inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"The add operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"type":"text","text":" "},{"text":"and listen to ","type":"text"},{"code":"onSourceDataLoaded","type":"codeVoice"},{"text":" (optionally pass the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"onMapLoadingError","type":"codeVoice"},{"type":"text","text":" with "},{"code":"type = metadata","type":"codeVoice"},{"type":"text","text":" if data parsing error has occurred."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"type":"text","text":" "},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":"event will be null.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"},{"style":"note","name":"Throws","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem adding features to the source."}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/addgeojsonsourcefeatures(forsourceid:features:dataid:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/addGeoJSONSourceFeatures(forSourceId:features:dataId:)"},"metadata":{"roleHeading":"Instance Method","role":"symbol","modules":[{"name":"MapboxMaps"}],"title":"addGeoJSONSourceFeatures(forSourceId:features:dataId:)","symbolKind":"method","externalID":"s:10MapboxMaps12StyleManagerC24addGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:10MapboxMaps7Featurea","text":"Feature","kind":"type