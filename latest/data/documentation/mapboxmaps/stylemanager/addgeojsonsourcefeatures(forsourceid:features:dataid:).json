xt":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","text":"Feature","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"? = nil)","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The identifier of the style source.","type":"text"}]}],"name":"sourceId"},{"name":"features","content":[{"type":"paragraph","inlineContent":[{"text":"An array of GeoJSON features to be added to the source.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The add operation will be scheduled and applied on a GeoJSON serialization queue."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"type":"text","text":" "},{"text":"and listen to ","type":"text"},{"code":"onSourceDataLoaded","type":"codeVoice"},{"type":"text","text":" (optionally pass the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter to filter the events)","type":"text"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"code":"type = metadata","type":"codeVoice"},{"type":"text","text":" if data parsing error has occurred."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"type":"text","text":" "},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"type":"text","text":" "},{"text":"in a ","type":"text"},{"type":"codeVoice","code":"map-loading-error"},{"text":".","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"text":"each batch will be included in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"type":"text","text":" "},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}],"style":"note","name":"Note","type":"aside"},{"style":"note","name":"Throws","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference"},{"text":" if there is a problem adding features to the source.","type":"text"}]}],"type":"aside"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/addgeojsonsourcefeatures(forsourceid:features:dataid:)"]}],"kind":"symbol","references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/StyleManager":{"navigatorTitle":[{"text":"StyleManager","kind":"identifier"}],"url":"\/documentation\/mapboxmaps\/stylemanager","abstract":[{"text":"Style manager is a base class for ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/MapboxMap","type":"reference","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Snapshotter","isActive":true,"type":"reference"},{"text":" that provides provides methods to manipulate Map Style at runtime.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager","type":"topic","title":"StyleManager","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"StyleManager"}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/StyleManager/addGeoJSONSourceFeatures(forSourceId:features:dataId:)":{"type":"topic","role":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/addGeoJSONSourceFeatures(forSourceId:features:dataId:)","url":"\/documentation\/mapboxmaps\/stylemanager\/addgeojsonsourcefeatures(forsourceid:features:dataid:)","title":"addGeoJSONSourceFeatures(forSourceId:features:dataId:)","abstract":[{"text":"Add additional features to a GeoJSON style source.","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text"