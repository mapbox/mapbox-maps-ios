","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"text":" ","type":"text"},{"text":"each batch will be included in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}],"type":"aside","style":"note","name":"Note"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem adding features to the source."}]}],"name":"Throws"}]}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Add additional features to a GeoJSON style source.","type":"text"}],"metadata":{"title":"addGeoJSONSourceFeatures(forSourceId:features:dataId:)","externalID":"s:10MapboxMaps12StyleManagerC24addGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:10MapboxMaps7Featurea","text":"Feature","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"