{"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/addGeoJSONSourceFeatures(forSourceId:features:dataId:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":" "},{"text":"sourceId","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"text":"Feature","kind":"typeIdentifier","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"? = nil)"}],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The identifier of the style source."}]}],"name":"sourceId"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An array of GeoJSON features to be added to the source.","type":"text"}]}],"name":"features"},{"content":[{"inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}],"type":"paragraph"}],"name":"dataId"}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The add operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"type":"codeVoice","code":"type = metadata"},{"text":" if data parsing error has occurred.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"type":"text","text":" "},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"text":" ","type":"text"},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"text":" parameter in the","type":"text"},{"text":" ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"text":" ","type":"text"},{"type":"text",