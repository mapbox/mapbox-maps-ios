{"abstract":[{"type":"text","text":"Remove features from a GeoJSON style source."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"removeGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"text":" ","kind":"text"},{"text":"sourceId","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"featureIds"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"text":"A style source identifier.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The Ids of the features that need to be removed from the source.","type":"text"}],"type":"paragraph"}],"name":"featureIds"},{"name":"dataId","content":[{"type":"paragraph","inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"The remove operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"text":" (optionally pass the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter to filter the events)"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if an error has occurred."}]},{"type":"paragraph","inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"type":"text","text":" "},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"text":"in a ","type":"text"},{"code":"map-loading-error","type":"codeVoice"},{"type":"text","text":"."}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"text":" parameter in the","type":"text"},{"type":"text","text":" "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{