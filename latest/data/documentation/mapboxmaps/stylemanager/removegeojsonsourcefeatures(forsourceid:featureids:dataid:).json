{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"abstract":[{"text":"Remove features from a GeoJSON style source.","type":"text"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/removegeojsonsourcefeatures(forsourceid:featureids:dataid:)"]}],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"removeGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":" "},{"text":"sourceId","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"featureIds","kind":"externalParam"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A style source identifier."}],"type":"paragraph"}],"name":"sourceId"},{"content":[{"inlineContent":[{"type":"text","text":"The Ids of the features that need to be removed from the source."}],"type":"paragraph"}],"name":"featureIds"},{"name":"dataId","content":[{"inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The remove operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}]},{"inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"text":" ","type":"text"},{"text":"and listen to ","type":"text"},{"code":"onSourceDataLoaded","type":"codeVoice"},{"text":" (optionally pass the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter to filter the events)"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"code":"type = metadata","type":"codeVoice"},{"type":"text","text":" if an error has occurred."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"text":" ","type":"text"},{"text":"each batch will be included in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"type":"text","text":" "},{"text":"call, the data ID in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference","isActive":true},{"type":"text","text":" if there is a problem removing features from the source."}]}],"name":"Throws","style":"note","type":"aside"}]}],"metadata":{"symbolKind":"method","externalID":"s:10MapboxMaps12StyleManagerC27removeGeoJSONSourceFeatures11forSourceId10featureIds04dataK0ySS_SaySSGSSSgtF","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"removeGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"text":"featureIds","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"?)"}],"title":"removeGeoJSONSourceFeatures(forSourceId:fea