:"sourceId"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"text":"featureIds","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}],"name":"sourceId"},{"content":[{"inlineContent":[{"text":"The Ids of the features that need to be removed from the source.","type":"text"}],"type":"paragraph"}],"name":"featureIds"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The remove operation will be scheduled and applied on a GeoJSON serialization queue."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"text":" with ","type":"text"},{"code":"type = metadata","type":"codeVoice"},{"text":" if an error has occurred.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"type":"text","text":" "},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"text":".","type":"text"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}]}],"name":"Note"},{"content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference"},{"type":"text","text":" if there is a problem removing features from the source."}],"type":"paragraph"}],"style":"note","name":"Throws","type":"aside"}],"kind":"content"}],"references