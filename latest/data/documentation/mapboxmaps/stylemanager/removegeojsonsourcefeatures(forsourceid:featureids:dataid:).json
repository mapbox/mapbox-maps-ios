a ID is provided in the most recent","type":"text"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"text":"event will be null.","type":"text"}]}],"name":"Note","style":"note","type":"aside"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference"},{"type":"text","text":" if there is a problem removing features from the source."}]}],"name":"Throws","type":"aside"}],"kind":"content"}],"kind":"symbol","metadata":{"symbolKind":"method","externalID":"s:10MapboxMaps12StyleManagerC27removeGeoJSONSourceFeatures11forSourceId10featureIds04dataK0ySS_SaySSGSSSgtF","role":"symbol","modules":[{"name":"MapboxMaps"}],"title":"removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"removeGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"featureIds"},{"text":": [","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Remove features from a GeoJSON style source."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/remo