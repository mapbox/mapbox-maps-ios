{"abstract":[{"type":"text","text":"Remove features from a GeoJSON style source."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"removeGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"sourceId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"featureIds"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"inlineContent":[{"text":"A style source identifier.","type":"text"}],"type":"paragraph"}]},{"name":"featureIds","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The Ids of the features that need to be removed from the source."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The remove operation will be scheduled and applied on a GeoJSON serialization queue."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"text":" (optionally pass the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter to filter the events)"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if an error has occurred."}]},{"type":"paragraph","inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in a "},{"code":"map-loading-error","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"text":"each batch will be included in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"code":"source-data-loaded","type":"codeVoice"},{"text":"event will be null.","type":"text"}]}]},{"style":"note","type":"aside","name":"Throws","content":[{"inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference"},{"type":"text","text":" if there is a problem removing features from the source."}],"type":"paragraph"}]}]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","role":"symbol","title":"removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"removeGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"text":"featureIds","kind":"externalParam"},{"kind":"text","text":": ["},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"?)"}],"externalID":"s:10MapboxMaps12StyleManagerC27removeGeoJSONSourceFeatures11forSourceId10featureIds04dataK0ySS_SaySSGSSSgtF","symbolKind":"method","modules":[{"name":"MapboxMaps"}]},"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/remo