ent":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"type":"text","text":" "},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}],"style":"note","type":"aside","name":"Note"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference","isActive":true},{"type":"text","text":" if there is a problem removing features from the source."}],"type":"paragraph"}],"type":"aside","name":"Throws","style":"note"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId: