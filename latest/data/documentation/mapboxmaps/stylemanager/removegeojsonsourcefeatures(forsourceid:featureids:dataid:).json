{"abstract":[{"text":"Remove features from a GeoJSON style source.","type":"text"}],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"removeGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"sourceId"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"featureIds","kind":"externalParam"},{"kind":"text","text":": ["},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}],"name":"sourceId"},{"name":"featureIds","content":[{"inlineContent":[{"type":"text","text":"The Ids of the features that need to be removed from the source."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}],"type":"paragraph"}],"name":"dataId"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The remove operation will be scheduled and applied on a GeoJSON serialization queue."}]},{"inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"code":"onMapLoadingError","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if an error has occurred."}],"type":"paragraph"},{"inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"type":"text","text":" "},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"text":" ","type":"text"},{"text":"in a ","type":"text"},{"type":"codeVoice","code":"map-loading-error"},{"text":".","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"text":" parameter in the","type":"text"},{"type":"text","text":" "},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"type":"text","text":" "},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"text":" ","type":"text"},{"text":"each batch will be included in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}],"name":"Note"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","isActive":true},{"text":" if there is a problem removing features from the source.","type":"text"}]}],"style":"note","name":"Throws"}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/removegeojsonsourcefeatures(forsourceid:featureids:dataid:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"removeGeoJSONSourceFeatures(forSourceId:featureIds:dataId:)","modules":[{"name":"MapboxMaps"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"removeGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"featureIds","kind":"externalParam"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"externalID":"s:10MapboxMaps12StyleManagerC27removeGeoJ