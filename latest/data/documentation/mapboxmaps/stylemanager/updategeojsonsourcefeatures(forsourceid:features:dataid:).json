{"abstract":[{"text":"Update existing features in a GeoJSON style source.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid:features:dataid:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"method","title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"text":": [","kind":"text"},{"text":"Feature","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"externalID":"s:10MapboxMaps12StyleManagerC27updateGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","role":"symbol","roleHeading":"Instance Method","modules":[{"name":"MapboxMaps"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/updateGeoJSONSourceFeatures(forSourceId:features:dataId:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"updateGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"text":" ","kind":"text"},{"text":"sourceId","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","text":"Feature","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"? = nil)","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"inlineContent":[{"type":"text","text":"A style source identifier."}],"type":"paragraph"}]},{"name":"features","content":[{"inlineContent":[{"text":"The GeoJSON features to be updated in the source.","type":"text"}],"type":"paragraph"}]},{"name":"dataId","content":[{"type":"paragraph","inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The update operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"code":"onSourceDataLoaded","type":"codeVoice"},{"text":" (optionally pass the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"onMapLoadingError","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if data parsing error has occurred."}],"type":"paragraph"},{"inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"text":" ","type":"text"},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"text":"in a ","type":"text"},{"code":"map-loading-error","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter in the","type":"text"},{"type":"text","text":" "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"text":"each batch will be included in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}]}],"style":"note"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","isActive":true},{"type":"text","text":" if there is a problem updating features in the source."}]}],"name":"Throws"}]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documen