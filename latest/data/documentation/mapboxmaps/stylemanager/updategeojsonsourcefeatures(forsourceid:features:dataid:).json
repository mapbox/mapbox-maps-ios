{"abstract":[{"text":"Update existing features in a GeoJSON style source.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager\/updateGeoJSONSourceFeatures(forSourceId:features:dataId:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid:features:dataid:)"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":" "},{"text":"sourceId","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"text":": [","kind":"text"},{"text":"Feature","preciseIdentifier":"s:10MapboxMaps7Featurea","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","kind":"typeIdentifier"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"? = nil)","kind":"text"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}],"name":"features"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"The update operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"type":"codeVoice","code":"onSourceDataLoaded"},{"type":"text","text":" (optionally pass the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"onMapLoadingError"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if data parsing error has occurred."}]},{"inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"text":" ","type":"text"},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"type":"text","text":" "},{"text":"in a ","type":"text"},{"code":"map-loading-error","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"text":" ","type":"text"},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}],"style":"note","type":"aside","name":"Note"},{"type":"aside","name":"Throws","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference","isActive":true},{"text":" if there is a problem updating features in the source.","type":"text"}]}]}]}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"updateGeoJSONSourceFeatures"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier","text":"Feature"},{"text":"], ","kind":"text"},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"?)","kind":"text"}],"role":"symbol","title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","m