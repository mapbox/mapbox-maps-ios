{"abstract":[{"text":"Update existing features in a GeoJSON style source.","type":"text"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:10MapboxMaps12StyleManagerC27updateGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"updateGeoJSONSourceFeatures"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"forSourceId"},{"kind":"text","text":": "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"text":"Feature","preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"symbolKind":"method","title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","role":"symbol","modules":[{"name":"MapboxMaps"}]},"sections":[],"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid:features:dataid:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"updateGeoJSONSourceFeatures"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"sourceId"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"features","kind":"externalParam"},{"kind":"text","text":": ["},{"kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps7Featurea","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","text":"Feature"},{"kind":"text","text":"], "},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"inlineContent":[{"text":"A style source identifier.","type":"text"}],"type":"paragraph"}]},{"name":"features","content":[{"inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}],"name":"dataId"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The update operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and listen to "},{"code":"onSourceDataLoaded","type":"codeVoice"},{"type":"text","text":" (optionally pass the "},{"code":"dataId","type":"codeVoice"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"type":"text","text":" with "},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if data parsing error has occurred."}],"type":"paragraph"},{"inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"text":" ","type":"text"},{"type":"text","text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result"},{"type":"text","text":" "},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"type":"text","text":"."}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within"},{"type":"text","text":" "},{"text":"each batch will be included in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":"event will be null."}],"type":"paragraph"}],"type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","type":"reference"},{"text":" if there is a problem updating features in the source.","type":"text"}]}],"style":"note","type":"aside","name":"Throws"}]}],"kind":"symbol","schemaVer