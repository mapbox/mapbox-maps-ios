{"kind":"symbol","abstract":[{"type":"text","text":"Update existing features in a GeoJSON style source."}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"forSourceId"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"sourceId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"text":"features","kind":"externalParam"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","text":"Feature","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}]},{"name":"features","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}]},{"name":"dataId","content":[{"inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The update operation will be scheduled and applied on a GeoJSON serialization queue."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"code":"onSourceDataLoaded","type":"codeVoice"},{"text":" (optionally pass the ","type":"text"},{"code":"dataId","type":"codeVoice"},{"type":"text","text":" parameter to filter the events)"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"onMapLoadingError"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"text":" if data parsing error has occurred.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"type":"text","text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"code":"map-loading-error","type":"codeVoice"},{"type":"text","text":"."}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"The method allows the user to provide a data ID, which will be returned as the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"text":" ","type":"text"},{"code":"source-data-loaded","type":"codeVoice"},{"text":" event. However, it’s important to note that multiple partial updates can be queued","type":"text"},{"type":"text","text":" "},{"text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial","type":"text"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"type":"codeVoice","code":"source-data-loaded"},{"text":" event. If no data ID is provided in the most recent","type":"text"},{"type":"text","text":" "},{"text":"call, the data ID in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}],"type":"paragraph"}],"name":"Note"},{"name":"Throws","content":[{"inlineContent":[{"type":"text","text":""},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError"},{"type":"text","text":" if there is a problem updating features in the source."}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","externalID":"s:10MapboxMaps12StyleManagerC27updateGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"text":": [","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps7Featurea","text":"Feature","kind":"typeIdentifier"},{"kind":"text","text":"], "},{"text":"dataId","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"modules":[{"name":"MapboxMaps"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourcei