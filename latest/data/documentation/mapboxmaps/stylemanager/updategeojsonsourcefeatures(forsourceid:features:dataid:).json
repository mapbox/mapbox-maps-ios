{"abstract":[{"type":"text","text":"Update existing features in a GeoJSON style source."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"text":"(","kind":"text"},{"text":"forSourceId","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"sourceId","kind":"internalParam"},{"kind":"text","text":": "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"text":": [","kind":"text"},{"text":"Feature","kind":"typeIdentifier","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Feature-swift.typealias","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}],"name":"sourceId"},{"name":"features","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}]},{"name":"dataId","content":[{"inlineContent":[{"text":"An arbitrary string used to track the given GeoJSON data.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The update operation will be scheduled and applied on a GeoJSON serialization queue."}],"type":"paragraph"},{"inlineContent":[{"text":"In order to capture events when actual data is drawn on the map please refer to Events API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"code":"onSourceDataLoaded","type":"codeVoice"},{"type":"text","text":" (optionally pass the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter to filter the events)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"onMapLoadingError","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"type = metadata"},{"type":"text","text":" if data parsing error has occurred."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs.","type":"text"},{"type":"text","text":" "},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"type":"text","text":" "},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"type":"text","text":" "},{"text":"in a ","type":"text"},{"code":"map-loading-error","type":"codeVoice"},{"text":".","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"type":"text","text":"call, the data ID in the "},{"type":"codeVoice","code":"source-data-loaded"},{"text":"event will be null.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleError","isActive":true},{"text":" if there is a problem updating features in the source.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Throws","style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/mapboxmaps\/stylemanager\/updategeojsonsourcefeatures(forsourceid:features:dataid:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Style","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleManager"]]},"metadata":{"symbolKind":"method","modules":[{"name":"MapboxMaps"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"updateGeoJSONSourceFeatures","kind":"identifier"},{"kind":"text","text":"("},{"text":"forSourceId","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"features"},{"kind":"text","text":": ["},{"text":"Feature","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps7Featurea"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"?)"}],"title":"updateGeoJSONSourceFeatures(forSourceId:features:dataId:)","roleHeading":"Instance Method","role":"symbol","externalID":"s:10MapboxMaps12StyleManagerC27updateGeoJSONSourceFeatures11forSourceId8features04dataK0ySS_Say4Turf7FeatureVGSSSgtF"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/M