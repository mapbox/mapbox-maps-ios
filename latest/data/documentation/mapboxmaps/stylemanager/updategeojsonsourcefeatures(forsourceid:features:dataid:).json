":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Feature","preciseIdentifier":"s:10MapboxMaps7Featurea","kind":"typeIdentifier","text":"Feature"},{"text":"], ","kind":"text"},{"kind":"externalParam","text":"dataId"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"? = nil)","kind":"text"}],"platforms":["iOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"sourceId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A style source identifier."}]}]},{"name":"features","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The GeoJSON features to be updated in the source."}]}]},{"name":"dataId","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An arbitrary string used to track the given GeoJSON data."}]}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"The update operation will be scheduled and applied on a GeoJSON serialization queue.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to capture events when actual data is drawn on the map please refer to Events API"},{"text":" ","type":"text"},{"type":"text","text":"and listen to "},{"code":"onSourceDataLoaded","type":"codeVoice"},{"text":" (optionally pass the ","type":"text"},{"type":"codeVoice","code":"dataId"},{"type":"text","text":" parameter to filter the events)"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"code":"onMapLoadingError","type":"codeVoice"},{"type":"text","text":" with "},{"code":"type = metadata","type":"codeVoice"},{"text":" if data parsing error has occurred.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Partially updating a GeoJSON source is not compatible with using shared cache and generated IDs."},{"text":" ","type":"text"},{"text":"It is important to ensure that every feature in the GeoJSON style source, as well as the newly added","type":"text"},{"text":" ","type":"text"},{"text":"feature, has a unique ID (or a unique promote ID if in use). Failure to provide unique IDs will result","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in a "},{"type":"codeVoice","code":"map-loading-error"},{"text":".","type":"text"}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The method allows the user to provide a data ID, which will be returned as the "},{"type":"codeVoice","code":"dataId"},{"text":" parameter in the","type":"text"},{"type":"text","text":" "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. However, it’s important to note that multiple partial updates can be queued"},{"type":"text","text":" "},{"type":"text","text":"for the same GeoJSON source when ongoing source parsing is taking place. In these cases, the partial"},{"text":" ","type":"text"},{"text":"updates will be applied to the source in batches. Only the data ID provided in the most recent call within","type":"text"},{"type":"text","text":" "},{"type":"text","text":"each batch will be included in the "},{"code":"source-data-loaded","type":"codeVoice"},{"type":"text","text":" event. If no data ID is provided in the most recent"},{"text":" ","type":"text"},{"text":"call, the data ID in the ","type":"text"},{"type":"codeVoice","code":"source-data-loaded"},{"type":"text","text":"event will be null."}]}]},{"type":"aside","name":"Throws","content":[{"inlineContent":[{"type":"text","text":""},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/StyleError","isActive":true},{"type":"text","text":" if there is a problem updating features in the source."}],"type":"paragraph"}],"style":"note"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documen