"text"},{"type":"codeVoice","code":"UIScreen.main.scale"},{"type":"text","text":", which is the default value."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The tilesets associated with the tileset descriptor. An array, each element of which must be either a URI to a TileJSON resource or a JSON string representing the inline tileset. The provided URIs must have “mapbox:\/\/” scheme, e.g. “mapbox:\/\/mapbox.mapbox-streets-v8”."}],"type":"paragraph"}],"name":"tilesets"},{"content":[{"inlineContent":[{"type":"text","text":"Style package load options, associated with the"},{"text":" ","type":"text"},{"text":"tileset descriptor.","type":"text"}],"type":"paragraph"}],"name":"stylePackOptions"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Extra tileset descriptor options. Must be a valid JSON object."}]}],"name":"extraOptions"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The implementation loads and stores the loaded tiles in batches,"},{"type":"text","text":" "},{"type":"text","text":"each batch has a pre-defined zoom range and it contains all child"},{"type":"text","text":" "},{"type":"text","text":"tiles within the range. The zoom leveling scheme for the tile batches"},{"type":"text","text":" "},{"text":"can be defined in Tile JSON, otherwise the default scheme is used:","type":"text"}]}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Global coverage: 0 - 5","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Regional information: 6 - 10"}]}]},{"content":[{"inlineContent":[{"text":"Local information: 11 - 14","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Streets detail: 15 - 16"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Internally, the implementation maps the given tile pack zoom range"},{"type":"text","text":" "},{"type":"text","text":"and geometry to a set of pre-defined batches to load, therefore"},{"text":" ","type":"text"},{"text":"it is highly recommended to choose the minZoom and maxZoom values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in accordance with the tile batches zoom ranges (see the list above)."}]},{"content":[{"inlineContent":[{"type":"text","text":"If a "},{"type":"codeVoice","code":"stylePackOptions"},{"text":" is provided, ","type":"text"},{"type":"codeVoice","code":"OfflineManager"},{"type":"text","text":" will create a"},{"type":"text","text":" "},{"type":"text","text":"style package while resolving the corresponding tileset descriptor"},{"text":" ","type":"text"},{"type":"text","text":"and load all the resources as defined in the provided style package"},{"type":"text","text":" "},{"type":"text","text":"options. i.e. resolving the corresponding tileset descriptor"},{"type":"text","text":" "},{"type":"text","text":"will be equivalent to calling the "},{"code":"loadStylePack()","type":"codeVoice"},{"text":" method of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"OfflineManager"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}]}],"variants":[{"paths":["\/documentation\/mapboxmaps\/tilesetdescriptoroptions\/init(styleuri:zoomrange:pixelratio:tilesets:stylepackoptions:extraoptions:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/TilesetDescriptorOptions\/init(styleURI:zoomRange:pixelRatio:tilesets:stylePackOptions:extraOptions:)","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Initializes a "},{"code":"TilesetDescriptorOptions","type":"codeVoice"},{"type":"text","text":" which is used in the crea