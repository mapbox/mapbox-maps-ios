"style package while resolving the corresponding tileset descriptor","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and load all the resources as defined in the provided style package"},{"type":"text","text":" "},{"text":"options. i.e. resolving the corresponding tileset descriptor","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be equivalent to calling the "},{"code":"loadStylePack()","type":"codeVoice"},{"text":" method of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"OfflineManager"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note","style":"note"}],"kind":"content"}],"metadata":{"roleHeading":"Initializer","modules":[{"relatedModules":["MapboxCoreMaps"],"name":"MapboxMaps"}],"role":"symbol","symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"styleURI","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"StyleURI","preciseIdentifier":"s:10MapboxMaps8StyleURIV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"zoomRange","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SN","text":"ClosedRange","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"text":">, ","kind":"text"},{"text":"pixelRatio","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"text":"?, ","kind":"text"},{"text":"tilesets","kind":"externalParam"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"kind":"text","text":"]?, "},{"kind":"externalParam","text":"stylePackOptions"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)MBMStylePackLoadOptions","text":"StylePackLoadOptions","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"extraOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Any","kind