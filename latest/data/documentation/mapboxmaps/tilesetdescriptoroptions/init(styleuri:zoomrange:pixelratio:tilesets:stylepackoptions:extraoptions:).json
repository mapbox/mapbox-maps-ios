{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/TilesetDescriptorOptions"]]},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilesetdescriptoroptions\/init(styleuri:zoomrange:pixelratio:tilesets:stylepackoptions:extraoptions:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"convenience"},{"text":" ","kind":"text"},{"kind":"keyword","text":"init"},{"text":"(","kind":"text"},{"text":"styleURI","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10MapboxMaps8StyleURIV","text":"StyleURI","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StyleURI","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"zoomRange","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ClosedRange","kind":"typeIdentifier","preciseIdentifier":"s:SN"},{"kind":"text","text":"<"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":">, "},{"text":"pixelRatio","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sf","text":"Float"},{"kind":"text","text":"? = nil, "},{"text":"tilesets","kind":"externalParam"},{"kind":"text","text":": ["},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"]?, "},{"text":"stylePackOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:objc(cs)MBMStylePackLoadOptions","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StylePackLoadOptions","kind":"typeIdentifier","text":"StylePackLoadOptions"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"extraOptions"},{"text":": ","kind":"text"},{"text":"Any","kind":"keyword"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The style associated with the tileset descriptor.","type":"text"}],"type":"paragraph"}],"name":"styleURI"},{"content":[{"inlineContent":[{"text":"Closed range zoom level for the tile package.","type":"text"}],"type":"paragraph"}],"name":"zoomRange"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pixel ratio to be accounted for when downloading raster"},{"type":"text","text":" "},{"type":"text","text":"tiles. Typically this should match the scale used by the "},{"code":"MapView","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"most likely ","type":"text"},{"type":"codeVoice","code":"UIScreen.main.scale"},{"text":", which is the default value.","type":"text"}]}],"name":"pixelRatio"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The tilesets associated with the tileset descriptor. An array, each element of which must be either a URI to a TileJSON resource or a JSON string representing the inline tileset. The provided URIs must have “mapbox:\/\/” scheme, e.g. “mapbox:\/\/mapbox.mapbox-streets-v8”.","type":"text"}]}],"name":"tilesets"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Style package load options, associated with the","type":"text"},{"text":" ","type":"text"},{"text":"tileset descriptor.","type":"text"}]}],"name":"stylePackOptions"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Extra tileset descriptor options. Must be a valid JSON object.","type":"text"}]}],"name":"extraOptions"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The implementation loads and stores the loaded tiles in batches,","type":"text"},{"type":"text","text":" "},{"text":"each batch has a pre-defined zoom range and it contains all child","type":"text"},{"type":"text","text":" "},{"text":"tiles within the range. The zoom leveling scheme for the tile batches","type":"text"},{"type":"text","text":" "},{"text":"can be defined in Tile JSON, otherwise the default scheme is used:","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Global coverage: 0 - 5","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Regional information: 6 - 10","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Local information: 11 - 14"}]}]},{"content":[{"inlineContent":[{"text":"Streets detail: 15 - 16","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Internally, the implementation maps the given tile pack zoom range"},{"type":"text","text":" "},{"type":"text","text":"and geometry to a set of pre-defined batches to load, therefore"},{"type":"text","text":" "},{"type":"text","text":"it is highly recommended to choose the minZoom and maxZoom values"},{"type":"text","text":" "},{"text":"in accordance with the tile batches zoom ranges (see the list above).","type":"text"}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"If a ","type":"text"},{"code":"stylePackOptions","type":"codeVoice"},{"type":"text","text":" is provided, "},{"type":"codeVoice","code":"OfflineManager"},{"type":"text","text":" will create a"},{"type":"text","text":" "},{"type":"text","text":"style package while resolving the corresponding tileset descriptor"},{"text":" ","type":"text"},{"text":"and load all the resources as defined in the provided style package","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"options. i.e. resolving the corresponding tileset descriptor"},{"type":"text","text":" "},{"type":"text","text":"will be equivalent to calling the "},{"code":"loadStylePack()","type":"codeVoice"},{"text":" method of","type":"text"},{"text":" ","type":"text"},{"code":"OfflineManager","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/TilesetDescriptorOptions\/init(styleURI:zoomRange:pixelRatio:tilesets:stylePackOptions:extraOptions:)"},"abstract":[{"type":"text","text":"Initializes a "},{"code":"TilesetDescriptorOptions","type":"codeVoice"},{"type":"text","text":" which is used in the creation of"},{"text":" ","type":"text"},{"type":"text","text":"a "},{"type":"codeVoice","code":"TilesetDescriptor"},{"type":"text","text":"."}],"metadata":{"externalID":"s:So27MBMTilesetDescriptorOptionsC10MapboxMapsE8styleURI9zoomRange10pixelRatio8tilesets0f4PackC005extraC0AbC05StyleG0V_SNys5UInt8VGSfSgSaySSGSgSo08MBMStylem4LoadC0CSgypSgtcfc","roleHeading":"Initializer","extendedModule":"MapboxCoreMaps","title":"init(styleURI:zoomRange:pixelRatio:tilesets:stylePackOptions:extraOptions:)","modules":[{"name":"MapboxMaps","relatedModules":["MapboxCoreMaps"]}],"symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"styleURI","kind":"externalParam"},{"kind":"text","text":": "},{"text":"StyleURI","kind":"typeIdentifier","preciseIdentifier":"s:10MapboxMaps8StyleURIV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"zoomRange"},{"text":": ","kind":"text"},{"text":"ClosedRange","kind":"typeIdentifier","preciseIdentifier":"s:SN"},{"text":"<","kind":"text"},{"text":"UInt8","kind":"typeIdentifier","preciseIdentifier":"s:s5UInt8V"},{"kind":"text","text":">, "},{"kind":"externalParam","text":"pixelRatio"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sf","text":"Float","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"tilesets"},{"text":": [","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"text":"]?, ","kind":"text"},{"text":"stylePackOp