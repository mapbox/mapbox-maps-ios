Identifier":"s:SS","kind":"typeIdentifier"},{"text":"]?, ","kind":"text"},{"text":"stylePackOptions","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/StylePackLoadOptions","preciseIdentifier":"c:objc(cs)MBMStylePackLoadOptions","text":"StylePackLoadOptions"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"extraOptions"},{"text":": ","kind":"text"},{"text":"Any","kind":"keyword"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["iOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The style associated with the tileset descriptor.","type":"text"}],"type":"paragraph"}],"name":"styleURI"},{"name":"zoomRange","content":[{"inlineContent":[{"text":"Closed range zoom level for the tile package.","type":"text"}],"type":"paragraph"}]},{"name":"pixelRatio","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pixel ratio to be accounted for when downloading raster"},{"type":"text","text":" "},{"type":"text","text":"tiles. Typically this should match the scale used by the "},{"type":"codeVoice","code":"MapView"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"most likely ","type":"text"},{"type":"codeVoice","code":"UIScreen.main.scale"},{"type":"text","text":", which is the default value."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The tilesets associated with the tileset descriptor. An array, each element of which must be either a URI to a TileJSON resource or a JSON string representing the inline tileset. The provided URIs must have “mapbox:\/\/” scheme, e.g. “mapbox:\/\/mapbox.mapbox-streets-v8”."}],"type":"paragraph"}],"name":"tilesets"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Style package load options, associated with the"},{"type":"text","text":" "},{"type":"text","text":"tileset descriptor."}]}],"name":"stylePackOptions"},{"content":[{"