{"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"kind":"symbol","metadata":{"externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"roleHeading":"Case","title":"TileStoreUsageMode.readAndUpdate","symbolKind":"case","modules":[{"name":"MapboxMaps"}],"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}],"role":"symbol"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All tile requests are converted to tile pack requests, i.e."},{"text":" ","type":"text"},{"type":"text","text":"the tile pack that includes the request tile will be loaded, and the tile extracted"},{"type":"text","text":" "},{"text":"from it. In this mode, no individual tile requests will be made.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This mode can be useful if the map trajectory is predefined and the user cannot pan","type":"text"},{"type":"text","text":" "},{"text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded","type":"text"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If users can pan freely, this mode is not recommended. Otherwise, panning","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"text":" ","type":"text"},{"type":"text","text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in"},{"type":"text","text":" "},{"text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode/readAndUpdate":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"type":"topic","role":"symbol","abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"title":"TileStoreUsageMode.readAndUpdate","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","url":"\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate","kind":"symbol"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps":{"abstract":[{"text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal.","type":"text"}],"kind":"symbol","role":"collection","title":"MapboxMaps","type":"topic","identifier":"doc:\/\/com.mapbox.MapboxMaps\/do