{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"All tile requests are converted to tile pack requests, i.e."},{"type":"text","text":" "},{"text":"the tile pack that includes the request tile will be loaded, and the tile extracted","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from it. In this mode, no individual tile requests will be made."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This mode can be useful if the map trajectory is predefined and the user cannot pan"},{"text":" ","type":"text"},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If users can pan freely, this mode is not recommended. Otherwise, panning"},{"type":"text","text":" "},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"type":"text","text":" "},{"text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"abst