{"metadata":{"title":"TileStoreUsageMode.readAndUpdate","externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","roleHeading":"Case","symbolKind":"case","modules":[{"name":"MapboxMaps"}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MBMTileStoreUsageModeReadAndUpdate"}]},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"All tile requests are converted to tile pack requests, i.e.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the tile pack that includes the request tile will be loaded, and the tile extracted"},{"text":" ","type":"text"},{"text":"from it. In this mode, no individual tile requests will be made.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This mode can be useful if the map trajectory is predefined and the user cannot pan","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"text":" ","type":"text"},{"type":"text","text":"in the vicinity of the user."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If users can pan freely, this mode is not recommended. Otherwise, panning"},{"text":" ","type":"text"},{"text":"will download tile packs instead of using individual tiles. Note that this means that we could first","type":"text"},{"text":" ","type":"text"},{"text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in","type":"text"},{"text":" ","type":"text"},{"text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"],"traits":[{"interfaceLanguage":"swift"}]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStore-APIs":{"type":"topic","role":"collectionGroup","kind":"article","title":"TileStore APIs","abstract":[],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","url":"\/documentation\/mapboxmaps\/tilestore-apis"},"doc://com.mapbox.MapboxMaps/documentation/Overview":{"title":"MapboxMaps Documentation","role":"collection","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","url":"\/documentation\/overview"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode":{"type":"topic","url":"\/documentation\/mapboxmaps\/tilestoreusagemode","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TileStoreUsageMode"}],"role":"symbol","abstract":[{"type":"text","text":"Describes tile store usage modes."}],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/docum