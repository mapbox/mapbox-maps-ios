{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate"},"abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}],"platforms":["iOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"All tile requests are converted to tile pack requests, i.e.","type":"text"},{"type":"text","text":" "},{"text":"the tile pack that includes the request tile will be loaded, and the tile extracted","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from it. In this mode, no individual tile requests will be made."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This mode can be useful if the map trajectory is predefined and the user cannot pan"},{"type":"text","text":" "},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If users can pan freely, this mode is not recommended. Otherwise, panning","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"type":"text","text":" "},{"type":"text","text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in"},{"type":"text","text":" "},{"type":"text","text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache."}]}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"variants":[{"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"role":"symbol","title":"TileStoreUsageMode.readAndUpdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"roleHeading":"Case","externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}],"modules":[{"name":"MapboxMaps"}]},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode/readAndUpdate":{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"role":"symbol","kind":"symbol","title":"TileStoreUsageMode.readAndUpdate","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"type":"topic","url":"\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps":{"url":"\/documentation\/mapboxmaps","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","abstract":[{"text":"Interactive, thoroughly customizable maps for iOS powered by vector tiles and Metal.","type":"text"}],"title":"Ma