{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"kind":"symbol","metadata":{"role":"symbol","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"roleHeading":"Case","modules":[{"name":"MapboxMaps"}],"externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","symbolKind":"case","title":"TileStoreUsageMode.readAndUpdate","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"languages":["swift"],"platforms":["iOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"All tile requests are converted to tile pack requests, i.e."},{"type":"text","text":" "},{"type":"text","text":"the tile pack that includes the request tile will be loaded, and the tile extracted"},{"type":"text","text":" "},{"text":"from it. In this mode, no individual tile requests will be made.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This mode can be useful if the map trajectory is predefined and the user cannot pan","type":"text"},{"type":"text","text":" "},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If users can pan freely, this mode is not recommended. Otherwise, panning"},{"text":" ","type":"text"},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"text":" ","type":"text"},{"text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode/readAndUpdate":{"abstract":[{"type":"text","text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server."}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"readAndUpdate","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MBMTileStoreUsageModeReadAndUpdate"}],"title":"TileStoreUsageMode.readAndUpdate","type":"topic","kind":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","url":"\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStore-APIs":{"type":"topic","url":"\/documentation\/mapboxmaps\/tilestore-apis","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","title":"TileStore APIs","kind":"article","role":"collectionGroup","abst