{"sections":[],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"metadata":{"externalID":"c:@E@MBMTileStoreUsageMode@MBMTileStoreUsageModeReadAndUpdate","symbolKind":"case","modules":[{"name":"MapboxMaps"}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"readAndUpdate","kind":"identifier"}],"roleHeading":"Case","role":"symbol","title":"TileStoreUsageMode.readAndUpdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readAndUpdate"}],"platforms":["iOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All tile requests are converted to tile pack requests, i.e."},{"text":" ","type":"text"},{"text":"the tile pack that includes the request tile will be loaded, and the tile extracted","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from it. In this mode, no individual tile requests will be made."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This mode can be useful if the map trajectory is predefined and the user cannot pan"},{"type":"text","text":" "},{"type":"text","text":"freely (e.g. navigation use cases), so that there is a good chance tile packs are already loaded"},{"text":" ","type":"text"},{"text":"in the vicinity of the user.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If users can pan freely, this mode is not recommended. Otherwise, panning"},{"text":" ","type":"text"},{"type":"text","text":"will download tile packs instead of using individual tiles. Note that this means that we could first"},{"type":"text","text":" "},{"text":"download an individual tile, and then a tile pack that also includes this tile. The individual tile in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the disk cache won’t be used as long as the up-to-date tile pack exists in the cache."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]},{"traits":[{"interfaceLanguage":"occ"}],"paths":["\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate"]}],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","interfaceLanguage":"swift"},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStore-APIs":{"type":"topic","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStore-APIs","url":"\/documentation\/mapboxmaps\/tilestore-apis","kind":"article","title":"TileStore APIs"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/TileStoreUsageMode/readAndUpdate":{"abstract":[{"text":"Tile store enabled for accessing local tile packs and for loading new tile packs from server.","type":"text"}],"url":"\/documentation\/mapboxmaps\/tilestoreusagemode\/readandupdate","type":"topic","title":"TileStoreUsageMode.readAndUpdate","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAndUpdate"}],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/TileStoreUsageMode\/readAndUpdate","navigatorTitle":[{"text":"MBMTileStoreUsageModeReadAndUpdate","kind":"identifier"}],"role":"symbol","kind":