{"abstract":[{"text":"When loading a map, if PrefetchZoomDelta is set to any number greater than 0, the map will first request a tile at zoom level lower than zoom - delta, but so that the zoom level is multiple of delta, in an attempt to display a full map at lower resolution as quick as possible. It will get clamped at the tile source minimum zoom.","type":"text"},{"type":"text","text":" "},{"text":"Default value: 4.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"prefetchZoomDelta"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":"?","kind":"text"}]}],"kind":"declarations"}],"kind":"symbol","variants":[{"paths":["\/documentation\/mapboxmaps\/vectorsource\/prefetchzoomdelta"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/VectorSource\/prefetchZoomDelta","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"MapboxMaps"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"prefetchZoomDelta","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":"?","kind":"text"}],"title":"prefetchZoomDelta","role":"symbol","externalID":"s:10MapboxMaps12VectorSourceV17prefetchZoomDeltaSdSgvp","roleHeading":"Instance Property","symbolKind":"property"},"hierarchy":{"paths":[["doc:\/\/MapboxMaps\/documentation\/MapboxMaps","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Sources","doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/VectorSource"]]},"references":{"doc://MapboxMaps/documentation/MapboxMaps/Sources":{"role":"collectionGroup","title":"Sources","kind":"article","identifier":"doc:\/\/MapboxMaps\/documentation\/MapboxMaps\/Sources","abstract":[]