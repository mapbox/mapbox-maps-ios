d don’t support clustering. For those cases use ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true,"type":"reference"},{"type":"text","text":" or Runtime Styling API, for example, "},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SymbolLayer","type":"reference"},{"type":"text","text":" with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource"},{"type":"text","text":"."}]},{"content":[{"inlineContent":[{"type":"text","text":"View Annotations appear above all content of MapView (e.g. layers, annotations, puck). If you need to display annotation between layers or below puck, use "},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To display a view annotation configure a UIView, create "},{"code":"ViewAnnotation","type":"codeVoice"},{"text":", and add it to the view annotation manager:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The annotation can be displayed on a layer feature referenced by it’s "},{"code":"layerId","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"featureId"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["annotation.annotatedFeature = .layerFeature(layerId: \"route-line\", featureId: \"sf-la\")"]},{"type":"paragraph","inlineContent":[{"text":"The view annotation automatica