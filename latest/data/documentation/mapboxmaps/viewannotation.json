{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"Use view annotations if you need to display interactive UIView bound to"},{"type":"text","text":" "},{"text":"a geographical coordinate or map feature.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The view annotations are great for displaying unique interactive features. However, they may be suboptimal for large amounts of data and don’t support clustering. For those cases use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation"},{"text":" or Runtime Styling API, for example, ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SymbolLayer","type":"reference","isActive":true},{"text":" with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"View Annotations appear above all content of MapView (e.g. layers, annotations, puck). If you need to display annotation between layers or below puck, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true},{"text":".","type":"text"}]}],"name":"Note","type":"aside","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To display a view annotation configure a UIView, create "},{"code":"ViewAnnotation","type":"codeVoice"},{"text":", and add it to the view annotation manager:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"]},{"type":"paragraph","inlineContent":[{"text":"The annotation can be displayed on a layer feature referenced by it’s ","type":"text"},{"code":"layerId","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"featureId"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["annotation.annotatedFeature = .layerFeature(layerId: \"route-line\", featureId: \"sf-la\")"]},{"inlineContent":[{"type":"text","text":"The view annotation automatically inserts and removes it’s view into the view hierarchy and updates its "},{"type":"codeVoice","code":"isHidden"},{"type":"text","text":" property."}],"type":"paragraph"},{"type":"aside","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Don’t set "},{"type":"codeVoice","code":"UIView.isHidden"},{"type":"text","text":" property to hide the annotation. Instead, use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/visible","isActive":true,"type":"reference"},{"text":" property.","type":"text"}],"type":"paragraph"}],"style":"important"},{"inlineContent":[{"type":"text","text":"When view content or layout is updated, use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/setNeedsUpdateSize()","type":"reference","isActive":true},{"text":" to update the the annotation size. It’s safe to use it multiple times, only one update will be performed.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["view.hintText = \"Less Traffic\"","annotation.setNeedsUpdateSize() \/\/ Updates the annotation size."],"type":"codeListing"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ViewAnnotation"},{"text":" uses ","type":"text"},{"type":"codeVoice","code":"UIView.systemLayoutSizeFitting(_:)"},{"type":"text","text":" to measure the view size. Make sure that your view returns the correct size (e.g. implemented using AutoLayout, or returns correct size from "},{"type":"codeVoice","code":"UIView.sizeThatFits(_:)"},{"type":"text","text":" when layout is manual)."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To remove annotation when it’s no longer needed, use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/remove()","isActive":true,"type":"reference"},{"type":"text","text":" method."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/mapboxmaps\/viewannotation"]}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/ViewAnnotationAnchor":{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotationAnchor","type":"topic","url":"\/documentation\/mapboxmaps\/viewannotationanchor","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Enum describing how to place view annotation relatively to geometry."}],"title":"ViewAnnotationAnchor","navigatorTitle":[{"kind":"identifier","text":"ViewAnnotationAnchor"}],"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ViewAnnotationAnchor"}]},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/ViewAnnotation/selected":{"type":"topic","abstract":[{"type":"text","text":"Specifies if this view annotation is selected meaning it should be placed on top of others."}],"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/selected","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"selected"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/mapboxmaps\/viewannotation\/selected","title":"selected","kind":"symbol"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/ViewAnnotation/remove()":{"type":"topic","identifier":"doc:\/\/com.mapbox.MapboxMaps\