e"},{"inlineContent":[{"text":"To display a view annotation configure a UIView, create ","type":"text"},{"type":"codeVoice","code":"ViewAnnotation"},{"text":", and add it to the view annotation manager:","type":"text"}],"type":"paragraph"},{"code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The annotation can be displayed on a layer feature referenced by it’s ","type":"text"},{"code":"layerId","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"featureId"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["annotation.annotatedFeature = .layerFeature(layerId: \"route-line\", featureId: \"sf-la\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The view annotation automatically inserts and removes it’s view into the view hierarchy and updates its "},{"code":"isHidden","type":"codeVoice"},{"type":"text","text":" property."}]},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t set "},{"code":"UIView.isHidden","type":"codeVoice"},{"type":"text","text":" property to hide the annotation. Instead, use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/visible"},{"type":"text","text":" property."}]}]},{"inlineContent":[{"type":"text","text":"When view content or layout is updated, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/setNeedsUpdateSize()"},{"type":"text","text":" to update the the annotation size. It’s safe to use it multiple times, only one update will be performed."}],"type":"paragraph"},{