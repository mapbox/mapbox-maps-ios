ve features. However, they may be suboptimal for large amounts of data and don’t support clustering. For those cases use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation"},{"type":"text","text":" or Runtime Styling API, for example, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SymbolLayer"},{"text":" with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource"},{"text":".","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"View Annotations appear above all content of MapView (e.g. layers, annotations, puck). If you need to display annotation between layers or below puck, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"text":"To display a view annotation configure a UIView, create ","type":"text"},{"code":"ViewAnnotation","type":"codeVoice"},{"type":"text","text":", and add it to the view annotation manager:"}],"type":"paragraph"},{"syntax":"swift","code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The annotation can be displayed on a layer feature referenced by it’s ","type":"text"},{"code":"layerId","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"featureId","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["annotation.annotatedFeature = .layerFeature(layerId: \"route-line\", featureId: \"sf-la\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The view annotation automatically inserts and removes it’s view into the view hierarchy and updates its "},{"code":"isHidden","type":"codeVoice"},{"type":"text","text":" property."}]},{"type":"aside","style":"important","content":[{"inlineContent":[{"text":"Don’t set ","type":"text"},{"code":"UIView.isHidden","type":"codeVoice"},{"type":"text","text":" property to hide the annotation. Instead, use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/visible","isActive":true,"type":"reference"},{"type":"text","text":" property."}],"type":"paragraph"}],"name":"Important"},{"inlineContent":[{"type":"text","text":"When view content or layout is updated, use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/setNeedsUpdateSize()","type":"reference","isActive":true},{"type":"text","text":" to update the the annotation size. It’s safe to use it multiple times, only one update will be performed."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["view.hintText = \"Less Traffic\"","annotation.setNeedsUpdateSize() \/\/ Updates the annotation size."]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"ViewAnnotation","type":"codeVoice"},{"type":"text","text":" uses "},{"type":"codeVoice","code":"UIView.systemLayoutSizeFitting(_:)"},{"type":"text","text":" to measure the view size. Make sure that your view returns the correct size (e.g. implemented using AutoLayout, or returns correct size from "},{"type":"codeVoice","code":"UIView.sizeThatFits(_:)"},{"type":"text","text":" when layout is manual)."}]}],"style":"note","name":"Note"},{"inlineContent":[{"text":"To remove annotation when it’s no longer needed, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewAnnotation\/remove()","isActive":true},{"type":"