at for displaying unique interactive features. However, they may be suboptimal for large amounts of data and don’t support clustering. For those cases use "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true,"type":"reference"},{"type":"text","text":" or Runtime Styling API, for example, "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SymbolLayer","type":"reference","isActive":true},{"type":"text","text":" with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/GeoJSONSource"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"View Annotations appear above all content of MapView (e.g. layers, annotations, puck). If you need to display annotation between layers or below puck, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/PointAnnotation","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"To display a view annotation configure a UIView, create ","type":"text"},{"type":"codeVoice","code":"ViewAnnotation"},{"text":", and add it to the view annotation manager:","type":"text"}]},{"code":["let view = CustomView()","view.icon = UIImage(named: \"traffic-icon\")","let annotation = ViewAnnotation(","  coordinate: CLLocationCoordinate(latitude: 10, longitude: 10),","  view: view)","mapView.viewAnnotations.add(annotation)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The annotation can be displayed on a layer feature referenced by it’s "},{"code":"layerId","type":"codeVoice"},{"type":"text","text":" and "},{"code":"featureId","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["annotation.annotatedFeature = .layerFeature(layerId: \"rou