pboxMaps\/Puck3D","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/MapReader","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/MapProxy","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/FeatureState","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/FollowPuckOptions","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/OverviewOptions","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/MapGestureHandlers","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/MapURLOpener","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ForEvery","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ArrayBuilder"]}],"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Viewport"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Currently, several types of viewport are supported:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow Puck viewport automatically tracks the user’s position on the map."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The former method is handy to set viewport only once, at map initialization time:","type":"text"}]},{"code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:"}],"type":"paragraph"},{"code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation","isActive":true},{"type":"text","text":" for more details about viewport animation."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","isActive":true,"type":"reference"},{"type":"text","text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to "},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","type":"reference"},{"type":"text","text":" event."}],"type":"paragraph"}]}],"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Viewport","kind":"identifier"}],"externalID":"s:10MapboxMaps8ViewportV","role":"symbol","symbolKind":"struct","roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"Viewport"}],"platforms":[{"unavailable":false,"beta":false,"deprecated":false,"name":"iOS","introducedAt":"13.0"},{"deprecated":false,"introducedAt":"13.0","beta":false,"name":"iPadOS","unavailable":false},{"introducedAt":"13.0","name":"Mac Catalyst","deprecated":false,"unavailable":false,"beta":false}],"modules":[{"name":"MapboxMaps"}],"title":"Viewport"},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/SwiftUI":{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI","role":"collectionGroup","url":"\/documentation\/mapboxmaps\/swiftui","kind":"article","abstract":[],"type":"topic","title":"SwiftUI"},"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Declarative-Map-Styling":{"title":"Declarative Map Styling","role":"article","type":"topic","abstract":[{"type":"text","text":"Simplify runtime style manipul