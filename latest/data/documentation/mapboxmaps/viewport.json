enter coordinate, zoom, bearing, pitch, and anchor."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Follow Puck viewport automatically tracks the user’s position on the map.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}]},{"code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:"}]},{"type":"codeListing","syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":true},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation"},{"text":" for more details about viewport animation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","type":"reference","isActive":true},{"text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)"},{"text":" event.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","interfaceLanguage":"swift"},"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/OptionalMapContent":{"abstract":[],"title":"OptionalMapContent","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OptionalMapContent","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OptionalMapContent"}],"kind":"symbol","url":"\/documentation\/mapboxmaps\/optionalmapcontent","role":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/OptionalMapContent