{"identifier":{"url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Viewport"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"Currently, several types of viewport are supported:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow Puck viewport automatically tracks the user’s position on the map."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}],"type":"paragraph"},{"code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation","isActive":true,"type":"reference"},{"text":" for more details about viewport animation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","isActive":true},{"type":"text","text":" allows you to read only the values th