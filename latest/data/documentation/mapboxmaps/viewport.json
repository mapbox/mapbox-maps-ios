nterrupt the ongoing viewport transition animation."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The former method is handy to set viewport only once, at map initialization time:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"]},{"inlineContent":[{"type":"text","text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:"}],"type":"paragraph"},{"code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completio