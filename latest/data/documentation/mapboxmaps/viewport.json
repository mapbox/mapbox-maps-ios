matically tracks the user’s position on the map.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport "},{"code":"Binding","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}],"type":"paragraph"},{"type":"codeListing","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"]},{"inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation"},{"text":" for more details about viewport animation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","isActive":true,"type":"reference"},{"type":"text","text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to "},{"isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","type":"reference"},{"type":"text","text":" event."}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/mapboxmaps\/viewport"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI"]]},"topicSections":[{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/camera","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/followPuck","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/isIdle","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/isStyleDefault","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/padding"]},{"anchor":"Instance-Methods","title":"Instance Methods","generated":true,"id