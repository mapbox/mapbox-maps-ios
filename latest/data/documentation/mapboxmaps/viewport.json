{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"Viewport","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"Viewport","kind":"identifier"}],"navigatorTitle":[{"text":"Viewport","kind":"identifier"}],"modules":[{"name":"MapboxMaps"}],"symbolKind":"struct","roleHeading":"Structure","role":"symbol","externalID":"s:10MapboxMaps8ViewportV"},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/com.mapbox.MapboxMaps\/SQ","doc:\/\/com.mapbox.MapboxMaps\/s8SendableP"],"title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Viewport"}],"platforms":["iOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Currently, several types of viewport are supported:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Follow Puck viewport automatically tracks the user’s position on the map.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport ","type":"text"},{"code":"Binding","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}],"type":"paragraph"},{"type":"codeListing","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"syntax":"swift"},{"inlineContent":[{"text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":t