ifiers":["doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/idle","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/styleDefault"],"generated":true},{"anchor":"Type-Methods","title":"Type Methods","identifiers":["doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/camera(center:anchor:zoom:bearing:pitch:)","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/followPuck(zoom:bearing:pitch:)","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/overview(geometry:bearing:pitch:geometryPadding:maxZoom:offset:)"],"generated":true},{"identifiers":["doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/Equatable-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"variants":[{"paths":["\/documentation\/mapboxmaps\/viewport"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport"},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Viewport"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Currently, several types of viewport are supported:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Follow Puck viewport automatically tracks the user’s position on the map."}]}]},{"content":[{"inlineContent":[{"text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport "},{"type":"codeVoice","code":"Binding"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}]},{"syntax":"swift","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:"}]},{"code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation","isActive":true,"type":"reference"},{"text":" for more details about viewport animation.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport"},{"text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to ","type":"text"},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","isActive":true,"type":"reference"},{"type":"text","text":" event."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.mapbox.MapboxMaps\/documentation\/Overview","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/SwiftUI"]]},"abstract":[{"type":"text","text":"Viewport represents the ways to position camera."}],"references":{"doc://com.mapbox.MapboxMaps/documentation/MapboxMaps/Map/onCameraChanged(action:)":{"abstract":[{"text":"Adds an action to perform when the camera is changed.","type":"text"}],"kind":"symbol","type":"topic","title":"onCameraChanged(action:)","role":"symbol","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","url":"\/documentation\/mapboxmaps\/map\/oncamerachanged(action:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kin