iewport, or passing the viewport "},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The former method is handy to set viewport only once, at map initialization time:"}],"type":"paragraph"},{"syntax":"swift","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"type":"codeListing"},{"inlineContent":[{"text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"]},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)","isActive":true},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation"},{"text":" for more de