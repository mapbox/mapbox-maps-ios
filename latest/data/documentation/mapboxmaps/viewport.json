t":"Default Style viewport sets the camera to the camera parameters defined in the Style root property. This type is used by default."}]}]},{"content":[{"inlineContent":[{"text":"Camera viewport allows to directly set camera using center coordinate, zoom, bearing, pitch, and anchor.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Overview viewport helps to focus the map camera on a specified Geometry with the minimum zoom level. For example, focus user attention on a route line."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Follow Puck viewport automatically tracks the user’s position on the map.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Idle viewport is activated when the user interacts with the map. You can also set it to interrupt the ongoing viewport transition animation.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Typically, you set viewport via two methods: by setting the constant initial viewport, or passing the viewport ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The former method is handy to set viewport only once, at map initialization time:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["struct StaticViewport: View {","    var body: some View {","        \/\/ Focus camera on Disneyland at zoom 10.","        Map(initialViewport: .camera(center: disneyland, zoom: 10))","    }","}","","private let disneyland = CLLocationCoordinate(latitude: 33.812092, longitude: -117.918976)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The latter method allows you to programmatically update the viewport at any time, with or without animations:","type":"text"}]},{"syntax":"swift","code":["struct UserLocationMap: View {","    \/\/ Initially, focus camera on US Disneyland.","    @State var viewport: Viewport = .camera(center: disneyland, zoom: 10)","","    var body: some View {","        VStack {","            Map(viewport: $viewport)","            Button(\"Jump to Paris Disneyland\") {","                \/\/ Later, update viewport with the different settings.","                viewport = .camera(center: CLLocationCoordinate2D(latitude: 48.868, longitude: 2.782), zoom: 12)","            }","            Button(\"Animate to User\") {","                \/\/ Or, update viewport with animation.","                withViewportAnimation {","                    viewport = .followPuck(zoom: 16, bearing: .heading, pitch: 60)","                }","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/withViewportAnimation(_:body:completion:)"},{"type":"text","text":" and "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/ViewportAnimation","isActive":true,"type":"reference"},{"type":"text","text":" for more details about viewport animation."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport","isActive":true,"type":"reference"},{"type":"text","text":" allows you to read only the values that you set. If you need to read the actual camera state values, subscribe to "},{"identifier":"doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Map\/onCameraChanged(action:)","type":"reference","isActive":true},{"type":"text","text":" event."}]}],"kind":"content"}],"topicSections":[{"identifiers":["doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/camera","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/followPuck","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/isIdle","doc:\/\/com.mapbox.MapboxMaps\/documentation\/MapboxMaps\/Viewport\/isSt